{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "verb",
    "device"
  ],
  "properties": {
    "verb": {
      "type": "string",
      "const": "STATUS"
    },
    "device": {
      "type": "string"
    },
    "register": {
      "type": "string"
    },
    "address": {
      "type": "string"
    },
    "value": {},
    "action": {
      "type": "string"
    },
    "dry_run": {
      "type": "boolean"
    },
    "category": {
      "type": "string"
    },
    "prompt": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
